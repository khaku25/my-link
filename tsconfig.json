{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolvePackageJsonImports": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "#components/*": ["./src/components/*"],
      "#lib/*": ["./src/lib/*"],
      "#hooks/*": ["./src/hooks/*"]
    }
  },
  "include": ["src"]
}